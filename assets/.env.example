# Copy to assets/.env and fill in as needed.
# The app builds and runs with these left blank — it only fails at sign-in,
# Firebase, Maps, and Gemini calls until real credentials are provided.

# Firebase API keys (from your Firebase project's GoogleService-Info.plist).
APPLE_API_KEY=
MACOS_API_KEY=

# Google Gemini API key (AI itinerary generation).
GEMINI_API_KEY=

# Set to true to skip realtime location sync during local development.
DISABLE_REALTIME_LOCATIONS=true

# Optional: GPS sync interval in seconds.
LOCATION_INTERVAL_UPDATE=
