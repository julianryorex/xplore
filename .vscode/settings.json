{
  "files.exclude": {
    "amplify/.config": true,
    "amplify/**/*-parameters.json": true,
    "amplify/**/amplify.state": true,
    "amplify/**/transform.conf.json": true,
    "amplify/#current-cloud-backend": true,
    "amplify/backend/amplify-meta.json": true,
    "amplify/backend/awscloudformation": true
  },
  "dart.flutterSdkPath": ".fvm/flutter_sdk",
  "dart.lineLength": 120,
  "files.watcherExclude": {
    "**/.fvm/**": true
  },
  "[dart]": {
    "editor.defaultFormatter": "Dart-Code.dart-code",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "quickfix.insertSemicolon": "explicit",
      "source.organizeImports": "explicit",
      "quickfix.add.trailingComma.multi": "explicit",
      "quickfix.add.const": "explicit",
      "quickfix.remove.const": "explicit",
      "quickfix.remove.unnecessaryNew.multi": "explicit",
      "quickfix.remove.nonNullAssertion.multi": "explicit",
      "quickfix.remove.questionMark.multi": "explicit"
    },
    "editor.rulers": [120]
  },
  "files.associations": {
    "string": "cpp"
  }
}
