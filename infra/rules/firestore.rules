rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function tripFields() {
      return [
        'title',
        'memberIds',
        'createdBy',
        'lastUpdatedBy',
        'createdAt',
        'lastUpdatedAt',
        'startDate',
        'endDate',
        'coverImageUrl',
      ];
    }

    function requiredTripFields() {
      return ['title', 'memberIds', 'createdBy', 'lastUpdatedBy', 'createdAt', 'lastUpdatedAt'];
    }

    function optionalTimestamp(data, field) {
      return !(field in data) || data[field] == null || data[field] is timestamp;
    }

    function optionalString(data, field, maxLength) {
      return !(field in data)
        || data[field] == null
        || (data[field] is string && data[field].size() <= maxLength);
    }

    function validTripShape(data) {
      return data.keys().hasOnly(tripFields())
        && data.keys().hasAll(requiredTripFields())
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 80
        && data.memberIds is list
        && data.memberIds.size() > 0
        && data.memberIds.size() <= 50
        && data.createdBy is string
        && data.createdBy.size() > 0
        && data.createdBy.size() <= 128
        && data.lastUpdatedBy is string
        && data.lastUpdatedBy.size() > 0
        && data.lastUpdatedBy.size() <= 128
        && data.createdAt is timestamp
        && data.lastUpdatedAt is timestamp
        && optionalTimestamp(data, 'startDate')
        && optionalTimestamp(data, 'endDate')
        && optionalString(data, 'coverImageUrl', 2048)
        && (!('startDate' in data) || !('endDate' in data) || data.startDate == null || data.endDate == null || data.startDate <= data.endDate);
    }

    function validTripCreate() {
      return isSignedIn()
        && validTripShape(request.resource.data)
        && request.resource.data.memberIds == [request.auth.uid]
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.lastUpdatedBy == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.lastUpdatedAt == request.time;
    }

    function isTripMember(tripId) {
      return isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.memberIds;
    }

    function itineraryFields() {
      return ['invitees', 'daily_plans', 'pins', 'last_updated'];
    }

    function validItinerarySeed(data) {
      return data.keys().hasOnly(itineraryFields())
        && data.keys().hasAll(itineraryFields())
        && data.invitees is list
        && data.daily_plans is list
        && data.pins is list
        && data.last_updated == request.time;
    }

    function validTripUpdate() {
      return isSignedIn()
        && request.auth.uid in resource.data.memberIds
        && request.auth.uid in request.resource.data.memberIds
        && validTripShape(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'title',
          'lastUpdatedBy',
          'lastUpdatedAt',
          'startDate',
          'endDate',
          'coverImageUrl',
        ])
        && request.resource.data.lastUpdatedBy == request.auth.uid
        && request.resource.data.lastUpdatedAt == request.time;
    }

    // Free-tier member cap (FEAT-003). Plus (20) waits on the paywall
    // (FEAT-020); enforce 6 until then. This is the authoritative guard — the
    // client also pre-checks for nicer messaging.
    function maxTripMembers() {
      return 6;
    }

    // Accepting an invite: a signed-in non-member adds *only themselves* to
    // memberIds (FEAT-003 open-link join). The added element must be the
    // caller's own uid and nothing else may change beyond the audit fields.
    function validTripJoin() {
      return isSignedIn()
        && !(request.auth.uid in resource.data.memberIds)
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.memberIds.hasAll(resource.data.memberIds)
        && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
        && request.resource.data.memberIds.size() <= maxTripMembers()
        && validTripShape(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'memberIds',
          'lastUpdatedBy',
          'lastUpdatedAt',
        ])
        && request.resource.data.lastUpdatedBy == request.auth.uid
        && request.resource.data.lastUpdatedAt == request.time;
    }

    function inviteFields() {
      return ['token', 'tripId', 'createdBy', 'createdAt', 'expiresAt', 'revoked', 'tripTitle', 'memberCount'];
    }

    function requiredInviteFields() {
      return ['token', 'tripId', 'createdBy', 'createdAt', 'revoked'];
    }

    function validInviteShape(data, tripId, token) {
      return data.keys().hasOnly(inviteFields())
        && data.keys().hasAll(requiredInviteFields())
        && data.token == token
        && data.tripId == tripId
        && data.createdBy is string
        && data.createdBy.size() > 0
        && data.createdBy.size() <= 128
        && data.createdAt is timestamp
        && data.revoked is bool
        && optionalTimestamp(data, 'expiresAt')
        && optionalString(data, 'tripTitle', 80)
        && (!('memberCount' in data) || data.memberCount is int);
    }

    function validInviteCreate(tripId, token) {
      return isTripMember(tripId)
        && validInviteShape(request.resource.data, tripId, token)
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.revoked == false;
    }

    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // Unique-handle claim registry (FEAT-015). The handle (lowercased) is the
    // doc id, so uniqueness == "doc does not exist". A signed-in user may claim a
    // free handle mapped to their own uid (create only fires when absent) and
    // release one they own; updates are disallowed so a handle change is always a
    // delete-old + create-new transaction. No one can steal or squat another
    // user's handle. Reads are open to signed-in users for availability checks.
    match /usernames/{handle} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(['uid'])
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /trips/{tripId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.memberIds;

      allow create: if validTripCreate();

      // Member edits OR a self-service invite join (FEAT-003).
      allow update: if validTripUpdate() || validTripJoin();

      // Invites: any signed-in user who holds the unguessable token (the doc
      // id) may read it to preview the trip before joining. Only trip members
      // may create invites; revoke (or refresh memberCount) and delete are
      // member-only. The token never grants trip-document read access.
      match /invites/{token} {
        allow read: if isSignedIn();

        allow create: if validInviteCreate(tripId, token);

        allow update: if isTripMember(tripId)
          && request.resource.data.token == resource.data.token
          && request.resource.data.tripId == resource.data.tripId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['revoked', 'memberCount']);

        allow delete: if isTripMember(tripId);
      }
    }

    // One itinerary document per trip. Trip members read; members may seed a
    // starter document (create-time or lazy on first load). Editing CRUD is
    // deferred (FEAT-006 follow-up / FEAT-024), so updates stay denied for now.
    match /itineraries/{tripId} {
      allow read: if isTripMember(tripId);

      allow create: if isTripMember(tripId)
        && validItinerarySeed(request.resource.data);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
