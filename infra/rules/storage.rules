rules_version = '2';

// FEAT-001 section 7: require authentication for gallery objects.
// Tighten to trip membership in FEAT-014.
service firebase.storage {
  match /b/{bucket}/o {

    match /gallery/{tripId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
