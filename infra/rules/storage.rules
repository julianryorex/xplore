rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Gallery objects are trip-scoped: gallery/{tripId}/{uid}/**.
    // Only members of trips/{tripId} (membership lives in the Firestore
    // `memberIds` array) may read the prefix, and a member may only write
    // under their own uid segment.
    match /gallery/{tripId}/{uid}/{allPaths=**} {
      function isTripMember() {
        return request.auth != null
          && request.auth.uid in firestore.get(/databases/(default)/documents/trips/$(tripId)).data.memberIds;
      }

      allow read: if isTripMember();
      allow write: if isTripMember() && request.auth.uid == uid;
    }

    // Profile avatars (FEAT-015): a user writes only their own avatar. Reads are
    // owner-only for now; peers fetch the synced copy via the tokenized download
    // URL stored on the profile (cross-device avatar fetch lands in FEAT-015 PR 2).
    match /avatars/{uid}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
