# Copy to terraform.tfvars (git-ignored) and fill in as needed.
# The defaults in variables.tf already target xplore-a7012, so most values are
# optional. The Apple Sign-In credentials are the main thing to add once the
# Apple Developer portal items exist.

project_id         = "xplore-a7012"
region             = "us-east1"
firestore_location = "nam5"
firestore_type     = "DATASTORE_MODE"

# Named Firestore Native database used by the Flutter app.
app_firestore_database_id = "xplore-app"
app_firestore_location    = "us-east1"

# Google Sign-In (interim provider, enabled ahead of Apple).
# Create an OAuth 2.0 "Web application" client in
# GCP Console > APIs & Services > Credentials (or let Firebase auto-create one
# when Google sign-in is first enabled), then paste its values here. The secret
# is sensitive — prefer TF_VAR_google_oauth_client_secret in CI.
# google_oauth_client_id     = "1234567890-xxxxxxxxxxxxxxxx.apps.googleusercontent.com"
# google_oauth_client_secret = "GOCSPX-xxxxxxxxxxxxxxxxxxxx"

# Apple Sign-In. The Services ID below matches the Apple Developer portal identifier. 
# Leave empty until the Key (.p8) exists. NOTE: if Apple was already enabled in the Firebase console, 
# you must `terraform import` the apple IdP resource before setting these and applying,
# or apply fails with "already exists" (see "Apple sign-in" in README.md).
# apple_services_id = "com.olympuslabs.xplore.signin"
# apple_team_id     = "XXXXXXXXXX"
# apple_key_id      = "XXXXXXXXXX"
# apple_private_key = <<-EOT
# -----BEGIN PRIVATE KEY-----
# ...contents of AuthKey_XXXXXXXXXX.p8...
# -----END PRIVATE KEY-----
# EOT
